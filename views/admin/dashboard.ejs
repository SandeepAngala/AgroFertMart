<%- include('../partials/admin-header', { activePage: 'dashboard' }) %>

<!-- ── KPI Cards ── -->
<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5 mb-8">
    <div class="kpi-card flex items-center gap-4">
        <div class="kpi-icon bg-blue-50 text-blue-500"><i class="fas fa-boxes"></i></div>
        <div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wide">Products</p>
            <p class="text-3xl font-black text-gray-800"><%= stats.totalProducts %></p>
        </div>
    </div>
    <div class="kpi-card flex items-center gap-4">
        <div class="kpi-icon bg-green-50 text-green-500"><i class="fas fa-shopping-bag"></i></div>
        <div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wide">Total Orders</p>
            <p class="text-3xl font-black text-gray-800"><%= stats.totalOrders %></p>
        </div>
    </div>
    <div class="kpi-card flex items-center gap-4">
        <div class="kpi-icon bg-yellow-50 text-yellow-500"><i class="fas fa-clock"></i></div>
        <div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wide">Pending</p>
            <p class="text-3xl font-black text-gray-800"><%= stats.pendingOrders %></p>
        </div>
    </div>
    <div class="kpi-card flex items-center gap-4">
        <div class="kpi-icon bg-purple-50 text-purple-500"><i class="fas fa-rupee-sign"></i></div>
        <div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wide">Revenue</p>
            <p class="text-2xl font-black text-gray-800">₹<%= stats.revenue ? stats.revenue.toLocaleString() : '—' %></p>
        </div>
    </div>
</div>

<!-- ── Quick Actions ── -->
<div class="bg-white rounded-2xl p-5 mb-8 shadow-sm">
    <h2 class="text-base font-black text-gray-700 mb-4">⚡ Quick Actions</h2>
    <div class="flex flex-wrap gap-3">
        <a href="/admin/products" class="quick-chip"><span class="chip-icon">📦</span> Manage Products</a>
        <a href="/admin/orders"   class="quick-chip"><span class="chip-icon">📋</span> View All Orders</a>
        <a href="/products"       class="quick-chip" target="_blank"><span class="chip-icon">🛒</span> Open Store</a>
        <button onclick="document.getElementById('add-product-modal').classList.remove('hidden')" class="quick-chip">
            <span class="chip-icon">➕</span> Add Product
        </button>
    </div>
</div>

<!-- ── Recent Orders ── -->
<div class="bg-white rounded-2xl shadow-sm overflow-hidden">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-50">
        <h2 class="font-black text-gray-800 text-base">📋 Recent Orders</h2>
        <a href="/admin/orders" class="text-green-600 text-xs font-bold hover:underline">View All →</a>
    </div>
    <div class="overflow-x-auto">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                <% recentOrders.forEach(order => { %>
                <tr>
                    <td class="font-mono text-xs text-gray-400">#<%= order._id.toString().slice(-8).toUpperCase() %></td>
                    <td>
                        <p class="font-bold text-gray-800 text-sm"><%= order.user ? order.user.username : 'Deleted User' %></p>
                        <p class="text-xs text-gray-400"><%= order.user ? order.user.email : '' %></p>
                    </td>
                    <td class="text-xs text-gray-500"><%= order.items.length %> item<%= order.items.length !== 1 ? 's' : '' %></td>
                    <td><span class="font-bold text-green-700">₹<%= order.total.toLocaleString() %></span></td>
                    <td>
                        <span class="status-pill status-<%= order.status %>"><%= order.status %></span>
                    </td>
                    <td class="text-xs text-gray-400"><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></td>
                </tr>
                <% }) %>
                <% if (recentOrders.length === 0) { %>
                <tr>
                    <td colspan="6" class="text-center text-gray-400 py-10 italic">No orders yet.</td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- ── Quick Add Product Modal ── -->
<div id="add-product-modal" class="modal-backdrop hidden">
    <div class="modal-box">
        <div class="modal-header">
            <h3 class="font-black text-gray-800 text-xl">Add New Product</h3>
            <button onclick="document.getElementById('add-product-modal').classList.add('hidden')"
                    class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-400 hover:bg-red-50 hover:text-red-400 transition">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="modal-body">
            <form action="/admin/products/add" method="POST" enctype="multipart/form-data">
                <div class="grid grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="af-label">Product Name</label>
                        <input type="text" name="name" class="af-input" required placeholder="e.g. NPK 19-19-19">
                    </div>
                    <div>
                        <label class="af-label">Category</label>
                        <select name="category" class="af-input" required>
                            <option value="Fertilizer">Fertilizer</option>
                            <option value="Pesticide">Pesticide</option>
                            <option value="Equipment">Equipment</option>
                            <option value="Seed">Seed</option>
                        </select>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="af-label">Price (₹)</label>
                        <input type="number" name="price" class="af-input" required min="1" placeholder="e.g. 450">
                    </div>
                    <div>
                        <label class="af-label">Badge</label>
                        <select name="badge" class="af-input">
                            <option value="">None</option>
                            <option value="NEW">⭐ NEW</option>
                            <option value="POPULAR">🔥 POPULAR</option>
                        </select>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="af-label">Description</label>
                    <textarea name="description" class="af-input" rows="3" placeholder="Brief product description…"></textarea>
                </div>
                <div class="mb-5">
                    <label class="af-label">Product Image</label>
                    <input type="file" name="image" class="af-input" accept="image/*"
                           style="padding:0.4rem 0.6rem; background:white;">
                </div>
                <button type="submit" class="w-full py-3 rounded-xl bg-gradient-to-r from-green-800 to-green-500 text-white font-black text-sm shadow hover:shadow-lg transition">
                    <i class="fas fa-plus mr-2"></i> ADD PRODUCT
                </button>
            </form>
        </div>
    </div>
</div>

<script>
document.getElementById('page-title').textContent       = 'Dashboard';
document.getElementById('page-breadcrumb').textContent  = 'Admin / Dashboard';
</script>

<%- include('../partials/admin-footer') %>
