<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login – AgroFertMart</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        body { background: #0a1f0e; min-height: 100vh; overflow: hidden; }

        .bg-particles {
            position: fixed; inset: 0; z-index: 0;
            background: radial-gradient(ellipse at 20% 50%, rgba(22,163,74,0.15) 0%, transparent 60%),
                        radial-gradient(ellipse at 80% 20%, rgba(16,185,129,0.1) 0%, transparent 50%),
                        radial-gradient(ellipse at 60% 80%, rgba(6,95,70,0.2) 0%, transparent 50%);
        }

        .auth-wrapper {
            position: relative; z-index: 10;
            min-height: 100vh; display: flex;
        }

        /* ── Left Panel ── */
        .left-panel {
            width: 55%;
            background: url('/images/bg-agro.jpg') center/cover no-repeat;
            position: relative;
            display: flex; flex-direction: column;
            justify-content: flex-end;
            padding: 3rem;
        }
        .left-panel::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(135deg, rgba(5,46,22,0.85) 0%, rgba(20,83,45,0.7) 100%);
        }
        .left-content { position: relative; z-index: 1; color: white; }

        /* ── Right Panel ── */
        .right-panel {
            width: 45%; display: flex; align-items: center;
            justify-content: center; padding: 2rem;
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(20px);
        }

        .auth-card {
            width: 100%; max-width: 420px;
            background: rgba(255,255,255,0.97);
            border-radius: 2rem;
            padding: 2.5rem;
            box-shadow: 0 40px 80px rgba(0,0,0,0.4);
        }

        /* ── Role Toggle ── */
        .role-toggle {
            display: flex; background: #f3f4f6; border-radius: 1rem; padding: 4px; margin-bottom: 2rem;
        }
        .role-btn {
            flex: 1; padding: 0.6rem 1rem; border-radius: 0.8rem; border: none;
            font-weight: 700; font-size: 0.85rem; cursor: pointer;
            transition: all 0.3s ease; color: #6b7280; background: transparent;
            font-family: 'Outfit', sans-serif; display: flex; align-items: center;
            justify-content: center; gap: 0.4rem;
        }
        .role-btn.active-farmer {
            background: linear-gradient(135deg, #166534, #16a34a);
            color: white;
            box-shadow: 0 4px 12px rgba(22,163,74,0.35);
        }
        .role-btn.active-admin {
            background: linear-gradient(135deg, #1e3a5f, #1d4ed8);
            color: white;
            box-shadow: 0 4px 12px rgba(29,78,216,0.35);
        }

        /* ── Input Group ── */
        .input-group {
            position: relative; margin-bottom: 1.25rem;
        }
        .input-group .icon {
            position: absolute; left: 1rem; top: 50%;
            transform: translateY(-50%); color: #9ca3af;
            transition: color 0.2s; z-index: 1;
        }
        .input-group input {
            width: 100% !important; padding: 0.85rem 1rem 0.85rem 2.8rem !important;
            border: 2px solid #e5e7eb !important; border-radius: 0.875rem !important;
            font-size: 0.9rem !important; background: #fafafa !important;
            font-family: 'Inter', sans-serif;
            transition: all 0.25s ease !important;
        }
        .input-group input:focus {
            border-color: #16a34a !important;
            box-shadow: 0 0 0 3px rgba(22,163,74,0.1) !important;
        }
        .input-group input:focus ~ .toggle-pw,
        .input-group:focus-within .icon { color: #16a34a; }

        .input-group.admin-mode input:focus { border-color: #1d4ed8 !important; box-shadow: 0 0 0 3px rgba(29,78,216,0.1) !important; }
        .input-group.admin-mode input:focus ~ .toggle-pw,
        .admin-mode .input-group:focus-within .icon { color: #1d4ed8; }

        .toggle-pw {
            position: absolute; right: 1rem; top: 50%;
            transform: translateY(-50%); color: #9ca3af;
            cursor: pointer; background: none; border: none;
            transition: color 0.2s; z-index: 2;
        }

        /* ── Submit Button ── */
        .submit-btn {
            width: 100%; padding: 0.9rem; border-radius: 1rem; border: none;
            font-weight: 800; font-size: 1rem; cursor: pointer;
            font-family: 'Outfit', sans-serif; letter-spacing: 0.05em;
            transition: all 0.3s ease; display: flex; align-items: center;
            justify-content: center; gap: 0.5rem; margin-top: 0.5rem;
        }
        #farmer-submit {
            background: linear-gradient(135deg, #166534, #16a34a);
            color: white; box-shadow: 0 6px 18px rgba(22,163,74,0.35);
        }
        #farmer-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(22,163,74,0.45); }
        #admin-submit {
            background: linear-gradient(135deg, #1e3a5f, #1d4ed8);
            color: white; box-shadow: 0 6px 18px rgba(29,78,216,0.35);
        }
        #admin-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(29,78,216,0.45); }

        /* ── Admin badge ── */
        .admin-badge {
            display: none; background: linear-gradient(135deg,#1e3a5f,#1d4ed8);
            color: white; border-radius: 0.75rem; padding: 0.75rem 1rem;
            font-size: 0.8rem; font-weight: 700; margin-bottom: 1.25rem;
            align-items: center; gap: 0.5rem;
        }
        .admin-badge.visible { display: flex; }

        /* ── Floating leaves decoration ── */
        .leaf { position: fixed; font-size: 1.5rem; opacity: 0.1; animation: floatLeaf linear infinite; }
        @keyframes floatLeaf {
            0%   { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            10%  { opacity: 0.12; }
            90%  { opacity: 0.08; }
            100% { transform: translateY(-20px) rotate(360deg); opacity: 0; }
        }

        @media (max-width: 768px) {
            .left-panel { display: none; }
            .right-panel { width: 100%; background: #0a1f0e; }
            body { overflow: auto; }
        }
    </style>
</head>
<body>

<!-- Floating leaves -->
<span class="leaf" style="left:5%; animation-duration:14s; animation-delay:0s;">🌿</span>
<span class="leaf" style="left:20%; animation-duration:18s; animation-delay:3s; font-size:1rem;">🍃</span>
<span class="leaf" style="left:75%; animation-duration:12s; animation-delay:6s;">🌾</span>
<span class="leaf" style="left:88%; animation-duration:20s; animation-delay:1s; font-size:2rem;">🌱</span>
<div class="bg-particles"></div>

<div class="auth-wrapper">

    <!-- ── Left Visual Panel ── -->
    <div class="left-panel">
        <div class="left-content">
            <div class="mb-8">
                <a href="/" class="text-green-400 text-sm font-bold uppercase tracking-widest flex items-center gap-2 mb-10 hover:text-white transition">
                    <i class="fas fa-arrow-left"></i> Back to Store
                </a>
                <div class="text-5xl font-black text-white mb-3 leading-tight">
                    🌱 AgroFertMart
                </div>
                <p class="text-green-200 text-lg font-medium">India's Trusted Farm Supply Platform</p>
            </div>

            <div class="space-y-5 mb-10">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center text-green-300">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div>
                        <p class="text-white font-bold text-sm">45+ Premium Products</p>
                        <p class="text-green-300 text-xs">Fertilizers, Pesticides, Equipment & Seeds</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center text-green-300">
                        <i class="fas fa-truck"></i>
                    </div>
                    <div>
                        <p class="text-white font-bold text-sm">Village Doorstep Delivery</p>
                        <p class="text-green-300 text-xs">Pan-India rural network coverage</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center text-green-300">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <div>
                        <p class="text-white font-bold text-sm">Secure Payments</p>
                        <p class="text-green-300 text-xs">Razorpay + Pay on Delivery options</p>
                    </div>
                </div>
            </div>

            <div class="border-t border-green-800/50 pt-6">
                <div class="flex items-center gap-3">
                    <div class="flex -space-x-2">
                        <div class="w-8 h-8 rounded-full bg-green-500 flex items-center justify-center text-white text-xs font-bold">R</div>
                        <div class="w-8 h-8 rounded-full bg-emerald-400 flex items-center justify-center text-white text-xs font-bold">M</div>
                        <div class="w-8 h-8 rounded-full bg-teal-500 flex items-center justify-center text-white text-xs font-bold">S</div>
                    </div>
                    <p class="text-green-200 text-sm"><strong class="text-white">12,000+</strong> farmers trust us</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Right Login Panel ── -->
    <div class="right-panel">
        <div class="auth-card">

            <!-- Header -->
            <div class="text-center mb-6">
                <div class="w-14 h-14 rounded-2xl bg-green-50 flex items-center justify-center text-3xl mx-auto mb-4">🌾</div>
                <h1 class="text-2xl font-black text-gray-800" id="login-title">Welcome Back, Farmer!</h1>
                <p class="text-gray-500 text-sm mt-1" id="login-subtitle">Sign in to manage your orders & farm supplies</p>
            </div>

            <!-- Alert -->
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-red-50 border border-red-200 text-red-600 rounded-xl px-4 py-3 text-sm font-medium flex items-center gap-2 mb-4">
                <i class="fas fa-exclamation-triangle"></i> <%= error %>
            </div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
            <div class="bg-green-50 border border-green-200 text-green-600 rounded-xl px-4 py-3 text-sm font-medium flex items-center gap-2 mb-4">
                <i class="fas fa-check-circle"></i> <%= success %>
            </div>
            <% } %>

            <!-- Role Toggle -->
            <div class="role-toggle" id="role-toggle">
                <button class="role-btn active-farmer" id="btn-farmer" onclick="switchRole('farmer')">
                    <i class="fas fa-tractor"></i> Farmer
                </button>
                <button class="role-btn" id="btn-admin" onclick="switchRole('admin')">
                    <i class="fas fa-user-shield"></i> Admin
                </button>
            </div>

            <!-- Admin Badge Notice -->
            <div class="admin-badge" id="admin-badge">
                <i class="fas fa-lock"></i>
                <div>
                    <p class="font-black text-xs">ADMIN PORTAL</p>
                    <p class="text-blue-200 text-xs font-medium">Full system access. Handle with care.</p>
                </div>
            </div>

            <!-- Login Form -->
            <form action="/auth/login" method="POST" id="login-form">
                <input type="hidden" name="loginAs" id="loginAs" value="farmer">

                <div class="input-group">
                    <i class="fas fa-user icon"></i>
                    <input type="text" name="username" id="username-input" required
                           value="<%= typeof username !== 'undefined' ? username : '' %>"
                           placeholder="Username">
                </div>

                <div class="input-group">
                    <i class="fas fa-lock icon"></i>
                    <input type="password" name="password" id="password-input" required placeholder="Password">
                    <button type="button" class="toggle-pw" onclick="togglePw()">
                        <i class="fas fa-eye" id="pw-eye"></i>
                    </button>
                </div>

                <div class="flex justify-between items-center mb-5 mt-1">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" class="rounded" name="remember">
                        <span class="text-xs text-gray-500 font-medium">Remember me</span>
                    </label>
                    <a href="/auth/forgot-password" class="text-xs font-bold text-green-700 hover:text-green-900 transition" id="forgot-link">
                        Forgot password?
                    </a>
                </div>

                <button type="submit" class="submit-btn" id="farmer-submit">
                    <i class="fas fa-sign-in-alt"></i> SIGN IN AS FARMER
                </button>
                <button type="submit" class="submit-btn" id="admin-submit" style="display:none;">
                    <i class="fas fa-user-shield"></i> SIGN IN AS ADMIN
                </button>
            </form>

            <div class="text-center mt-6 pt-6 border-t border-gray-100">
                <p class="text-gray-500 text-sm">New to AgroFertMart?</p>
                <a href="/auth/signup" class="inline-block mt-2 text-green-700 font-bold text-sm hover:text-green-900 transition">
                    Create a Farmer Account <i class="fas fa-arrow-right ml-1 text-xs"></i>
                </a>
            </div>
        </div>
    </div>

</div>

<script>
function switchRole(role) {
    const btnFarmer   = document.getElementById('btn-farmer');
    const btnAdmin    = document.getElementById('btn-admin');
    const loginAs     = document.getElementById('loginAs');
    const badge       = document.getElementById('admin-badge');
    const title       = document.getElementById('login-title');
    const subtitle    = document.getElementById('login-subtitle');
    const farmerBtn   = document.getElementById('farmer-submit');
    const adminBtn    = document.getElementById('admin-submit');
    const icon        = document.querySelector('.auth-card .w-14 .text-3xl') || document.querySelector('.auth-card .text-3xl');
    const forgotLink  = document.getElementById('forgot-link');
    const inputs      = document.querySelectorAll('.input-group');

    if (role === 'admin') {
        btnAdmin.classList.add('active-admin');
        btnFarmer.classList.remove('active-farmer');
        loginAs.value = 'admin';
        badge.classList.add('visible');
        title.textContent = 'Admin Portal';
        subtitle.textContent = 'Full access to manage products, orders & users';
        farmerBtn.style.display = 'none';
        adminBtn.style.display  = 'flex';
        forgotLink.style.display = 'none';
        document.querySelectorAll('.input-group').forEach(g => g.classList.add('admin-mode'));
        document.querySelectorAll('.input-group input').forEach(i => {
            i.style.borderColor = '';
        });
    } else {
        btnFarmer.classList.add('active-farmer');
        btnAdmin.classList.remove('active-admin');
        loginAs.value = 'farmer';
        badge.classList.remove('visible');
        title.textContent = 'Welcome Back, Farmer!';
        subtitle.textContent = 'Sign in to manage your orders & farm supplies';
        farmerBtn.style.display = 'flex';
        adminBtn.style.display  = 'none';
        forgotLink.style.display = '';
        document.querySelectorAll('.input-group').forEach(g => g.classList.remove('admin-mode'));
    }
}

function togglePw() {
    const input = document.getElementById('password-input');
    const eye   = document.getElementById('pw-eye');
    if (input.type === 'password') {
        input.type = 'text';
        eye.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
        input.type = 'password';
        eye.classList.replace('fa-eye-slash', 'fa-eye');
    }
}
</script>
</body>
</html>
