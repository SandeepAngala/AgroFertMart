<%- include('../partials/header') %>

<div class="max-w-7xl mx-auto py-12 px-4">
    <h1 class="text-4xl font-bold text-green-900 mb-8"><i class="fas fa-shopping-cart mr-3"></i> Your Shopping Cart</h1>

    <% if (!cart || cart.items.length === 0) { %>
        <div class="glass-panel p-16 text-center animate-up">
            <div class="text-8xl text-green-100 mb-8">
                <i class="fas fa-shopping-basket"></i>
            </div>
            <h2 class="text-3xl font-black text-gray-800 mb-4 italic">Your cart is currently empty</h2>
            <p class="text-gray-500 mb-10 text-lg">Looks like you haven't added anything to your cart yet.</p>
            <a href="/products" class="btn-agro px-12 py-4 shadow-xl">
                Browse Full Catalog
            </a>
        </div>
<% } else { %>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
            <!-- Items List -->
            <div class="lg:col-span-2 space-y-8 animate-up">
                <% cart.items.forEach(item => { %>
                    <div id="item-<%= item.productId %>" class="glass-panel p-8 flex flex-wrap items-center gap-8 agro-card">
                        <div class="w-32 h-32 overflow-hidden rounded-3xl border-4 border-white shadow-inner flex-shrink-0">
                            <img src="<%= item.image_url.startsWith('http') ? item.image_url : '/uploads/' + item.image_url %>" alt="<%= item.name %>" class="w-full h-full object-cover">
                        </div>
                        
                        <div class="flex-grow min-w-0">
                            <h3 class="text-xl font-bold text-gray-800 mb-1 truncate"><%= item.name %></h3>
                            <p class="text-green-700 font-bold mb-4">₹<%= item.price.toLocaleString() %></p>
                            
                            <div class="flex items-center gap-4">
                                <div class="flex items-center border border-gray-200 rounded-xl overflow-hidden">
                                    <button onclick="updateQty('<%= item.productId %>', <%= item.quantity - 1 %>)" class="px-3 py-1 hover:bg-gray-100 text-gray-600 transition">
                                        <i class="fas fa-minus text-xs"></i>
                                    </button>
                                    <span class="px-4 py-1 font-bold text-gray-700 min-w-[3rem] text-center"><%= item.quantity %></span>
                                    <button onclick="updateQty('<%= item.productId %>', <%= item.quantity + 1 %>)" class="px-3 py-1 hover:bg-gray-100 text-gray-600 transition">
                                        <i class="fas fa-plus text-xs"></i>
                                    </button>
                                </div>
                                <button onclick="removeItem('<%= item.productId %>')" class="text-red-400 hover:text-red-600 transition text-sm font-semibold">
                                    <i class="fas fa-trash-alt mr-1"></i> Remove
                                </button>
                            </div>
                        </div>
                        
                        <div class="text-right ml-auto min-w-[6rem]">
                            <p class="text-xs text-gray-400 mb-1 uppercase tracking-wider font-bold">Subtotal</p>
                            <p id="subtotal-<%= item.productId %>" class="text-xl font-black text-gray-800">
                                ₹<%= (item.price * item.quantity).toLocaleString() %>
                            </p>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Summary -->
            <div class="lg:col-span-1">
                <div class="glass-panel p-10 sticky top-24 border-green-100">
                    <h2 class="text-3xl font-black text-gray-800 mb-8 italic">Summary</h2>
                    
                    <div class="space-y-6 mb-10">
                        <div class="flex justify-between text-gray-500 font-bold uppercase tracking-widest text-xs">
                            <span>Subtotal</span>
                            <span id="summary-subtotal" class="text-gray-800">₹<%= cart.total.toLocaleString() %></span>
                        </div>
                        <div class="flex justify-between text-gray-500 font-bold uppercase tracking-widest text-xs">
                            <span>Shipping</span>
                            <span class="text-green-600">FREE</span>
                        </div>
                        <div class="pt-6 border-t border-gray-100 flex justify-between items-end">
                            <span class="text-xl font-black text-gray-800 italic">Total</span>
                            <span id="summary-total" class="text-4xl font-black text-green-700 italic">
                                ₹<%= cart.total.toLocaleString() %>
                            </span>
                        </div>
                    </div>
                    
                    <a href="/orders/checkout" class="btn-agro w-full text-xl py-5 shadow-2xl">
                        PROCEED TO CHECKOUT <i class="fas fa-arrow-right ml-2 text-sm"></i>
                    </a>
                    
                    <div class="mt-6 flex justify-center gap-4 text-gray-400 text-xl">
                        <i class="fab fa-cc-visa"></i>
                        <i class="fab fa-cc-mastercard"></i>
                        <i class="fas fa-university"></i>
                        <i class="fas fa-money-check-alt"></i>
                    </div>
                </div>
            </div>
        </div>
    <% } %>
</div>

<script>
    function updateQty(productId, quantity) {
        if (quantity < 0) return;
        
        fetch('/cart/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId, quantity })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                if (quantity === 0) {
                    document.getElementById('item-' + productId).remove();
                    if (data.count === 0) location.reload();
                } else {
                    location.reload(); // Simplest way to keep everything sync'd for now
                }
                document.getElementById('cart-badge').textContent = data.count;
            }
        })
        .catch(err => console.error(err));
    }

    function removeItem(productId) {
        if (!confirm('Are you sure you want to remove this item?')) return;
        updateQty(productId, 0);
    }
</script>

<%- include('../partials/footer') %>
