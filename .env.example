# Copy this file to .env and fill in real values before running the app
# Do NOT commit your real .env to source control

# MongoDB connection string (MongoDB Atlas or local). Example:
# MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/agrofertmart?retryWrites=true&w=majority
MONGODB_URI=

# Session secret used by express-session
SESSION_SECRET=change-me-to-a-secure-string

# Optional port (defaults to 3000)
PORT=3000

# Razorpay keys (if using payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional: enable seed import by running `node seed.js`
