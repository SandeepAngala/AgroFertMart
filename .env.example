# ─── AgroFertMart Environment Variables ───────────────
# Copy this file to .env and fill in real values.
# On Render, set these in Dashboard → Environment → Env Vars

# MongoDB Atlas connection string (REQUIRED)
# Example: mongodb+srv://user:pass@cluster0.mongodb.net/agrofertmart?retryWrites=true&w=majority
MONGODB_URI=

# Session secret (REQUIRED in production — use a long random string)
SESSION_SECRET=change-me-to-a-secure-string

# Port (optional — Render sets this automatically)
PORT=3000

# Node environment (Render sets this automatically)
# NODE_ENV=production

# Razorpay payment keys (optional — needed for payment feature)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
